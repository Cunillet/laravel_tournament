# ──────────────────────────────────────────────
# APP CONFIGURATION
# ──────────────────────────────────────────────
APP_NAME=DD_Tournaments
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

# ──────────────────────────────────────────────
# DATABASE (MySQL 8)
# ──────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=dd_tournaments
DB_USERNAME=dd_user
DB_PASSWORD=root_password

# ──────────────────────────────────────────────
# REDIS (Sessions & Cache)
# ──────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ──────────────────────────────────────────────
# SESSION
# ──────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ──────────────────────────────────────────────
# CACHE
# ──────────────────────────────────────────────
CACHE_STORE=redis

# ──────────────────────────────────────────────
# QUEUE
# ──────────────────────────────────────────────
QUEUE_CONNECTION=redis

# ──────────────────────────────────────────────
# MAIL (Not used yet)
# ──────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ──────────────────────────────────────────────
# LOGGING
# ──────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ──────────────────────────────────────────────
# FILESYSTEMS
# ──────────────────────────────────────────────
FILESYSTEM_DISK=local
